# PORT: Server listen port.
PORT=3002

# GITHUB_TOKEN: GitHub Personal Access Token.
# Used to authenticate API requests to fetch repositories, topics, issues, PRs, and checks.
GITHUB_TOKEN=""

# GITHUB_DASHBOARD_SCAN_ROOTS: Colon-separated absolute directories scanned read-only for local git checkouts.
# This is non-secret configuration and is required for /api/local/checkouts.
GITHUB_DASHBOARD_SCAN_ROOTS="/absolute/path/to/checkouts:/another/absolute/root"
